{
  "expo": {
    "name": "Match Sport 24",
    "slug": "match-sport-24",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "matchsport24",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matchsport24.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "Per scattare foto del tuo profilo",
        "NSPhotoLibraryUsageDescription": "Per scegliere foto dalla galleria",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.matchsport24.app",
      "versionCode": 6,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permetti a Match Sport 24 di accedere alle tue foto",
          "cameraPermission": "Permetti a Match Sport 24 di accedere alla fotocamera"
        }
      ],
      "expo-iap",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "kotlinVersion": "2.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "locales": {
      "it": "./locales/it.json",
      "en": "./locales/en.json",
      "es": "./locales/es.json",
      "fr": "./locales/fr.json"
    },
    "extra": {
      "eas": {
        "projectId": "001160bc-cc77-47f7-99d8-40bc720c9ded"
      },
      "backendUrl": "https://padel-finder-app.preview.emergentagent.com"
    },
    "owner": "match24",
    "primaryColor": "#10B981",
    "backgroundColor": "#0F172A"
  }
}
